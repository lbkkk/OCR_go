# Normalize line endings to LF for text files in the repo.
* text=auto eol=lf

# Go and common text files always use LF.
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Windows scripts keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets: no line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.docx binary
